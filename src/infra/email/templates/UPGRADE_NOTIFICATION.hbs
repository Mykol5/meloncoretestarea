<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Team Member Waiting - Melon Solutions</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #1f2937;
      background-color: #f9fafb;
      margin: 0;
      padding: 0;
    }
    
    .email-wrapper {
      background-color: #f9fafb;
      padding: 40px 20px;
      min-height: 100vh;
    }
    
    .email-container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #ffffff;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid #e5e7eb;
    }
    
    .header {
      background-color: #ffffff;
      padding: 32px 40px;
      border-bottom: 1px solid #e5e7eb;
    }
    
    .logo {
      font-size: 24px;
      font-weight: 700;
      color: #1f2937;
      margin: 0;
      letter-spacing: -0.5px;
    }
    
    .logo-accent {
      color: #5B94E5;
    }
    
    .content {
      padding: 48px 40px;
    }
    
    .greeting {
      font-size: 16px;
      color: #1f2937;
      margin: 0 0 24px 0;
      font-weight: 500;
    }
    
    .message {
      font-size: 15px;
      color: #4b5563;
      margin: 0 0 32px 0;
      line-height: 1.6;
    }
    
    .alert-card {
      background-color: #fffbeb;
      border: 1px solid #fde68a;
      border-left: 3px solid #f59e0b;
      border-radius: 6px;
      padding: 24px;
      margin: 32px 0;
    }
    
    .alert-title {
      font-size: 16px;
      font-weight: 600;
      color: #92400e;
      margin: 0 0 16px 0;
    }
    
    .blocked-user {
      font-size: 15px;
      color: #78350f;
      background-color: #fef3c7;
      padding: 12px 16px;
      border-radius: 4px;
      margin: 16px 0;
      border: 1px solid #fde68a;
    }
    
    .blocked-user strong {
      color: #92400e;
      font-weight: 600;
    }
    
    .alert-description {
      font-size: 14px;
      color: #92400e;
      margin: 16px 0 0 0;
      line-height: 1.5;
    }
    
    .cta-section {
      margin: 32px 0;
    }
    
    .cta-button {
      display: inline-block;
      background-color: #5B94E5;
      color: #ffffff;
      padding: 14px 32px;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 600;
      font-size: 15px;
      transition: background-color 0.2s ease;
    }
    
    .cta-button:hover {
      background-color: #4A7EC9;
    }
    
    .benefits-section {
      background-color: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      padding: 24px;
      margin: 32px 0;
    }
    
    .benefits-title {
      font-size: 15px;
      font-weight: 600;
      color: #1f2937;
      margin: 0 0 16px 0;
    }
    
    .benefits-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    
    .benefits-list li {
      font-size: 14px;
      color: #4b5563;
      padding: 8px 0;
      line-height: 1.5;
      position: relative;
      padding-left: 24px;
    }
    
    .benefits-list li:before {
      content: "•";
      position: absolute;
      left: 8px;
      color: #5B94E5;
      font-weight: 600;
    }
    
    .urgency-note {
      margin: 32px 0 0 0;
      padding: 16px 20px;
      background-color: #fef2f2;
      border-left: 3px solid #ef4444;
      border-radius: 4px;
    }
    
    .urgency-note p {
      font-size: 14px;
      color: #991b1b;
      margin: 0;
      line-height: 1.5;
    }
    
    .footer {
      background-color: #f9fafb;
      padding: 32px 40px;
      border-top: 1px solid #e5e7eb;
      text-align: center;
    }
    
    .footer-content {
      font-size: 13px;
      color: #6b7280;
      margin: 0 0 16px 0;
      line-height: 1.5;
    }
    
    .footer-links {
      margin: 16px 0;
    }
    
    .footer-link {
      color: #5B94E5;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      margin: 0 12px;
    }
    
    .footer-link:hover {
      text-decoration: underline;
    }
    
    .footer-bottom {
      font-size: 12px;
      color: #9ca3af;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid #e5e7eb;
    }
    
    @media (max-width: 600px) {
      .email-wrapper {
        padding: 20px 10px;
      }
      
      .header,
      .content,
      .footer {
        padding-left: 24px;
        padding-right: 24px;
      }
      
      .alert-card,
      .benefits-section {
        padding: 16px;
      }
      
      .footer-link {
        display: block;
        margin: 8px 0;
      }
    }
  </style>
</head>
<body>
  <div class="email-wrapper">
    <div class="email-container">
      
      <!-- Header -->
      <div class="header">
        <h1 class="logo">
          <span class="logo-accent">Melon Solutions</span>
        </h1>
      </div>

      <!-- Content -->
      <div class="content">
        <p class="greeting">Hello {{ownerName}},</p>
        
        <p class="message">
          A team member attempted to join your organization but was unable to complete registration due to your current plan limits.
        </p>

        <!-- Alert Card -->
        <div class="alert-card">
          <h2 class="alert-title">User Registration Blocked</h2>

          <div class="blocked-user">
            <strong>{{blockedUserEmail}}</strong> attempted to join <strong>{{organizationName}}</strong>
          </div>

          <p class="alert-description">
            Your current plan has reached its user limit. Upgrade your plan to allow additional team members to join your organization.
          </p>
        </div>

        <p class="message">
          Expand your team's capabilities by upgrading to a plan that supports more users. Your colleague is ready to start collaborating on impact measurement projects.
        </p>

        <div class="cta-section">
          <a href="{{upgradeUrl}}" class="cta-button">
            Upgrade Plan
          </a>
        </div>

        <!-- Benefits Section -->
        <div class="benefits-section">
          <h3 class="benefits-title">Upgrade to unlock:</h3>
          <ul class="benefits-list">
            <li>Add more team members to your organization</li>
            <li>Enhanced collaboration features</li>
            <li>Advanced impact measurement capabilities</li>
            <li>Increased project and report limits</li>
          </ul>
        </div>

        <!-- Urgency Note -->
        <div class="urgency-note">
          <p>
            Act now to enable {{blockedUserEmail}} to join your team and start contributing to your impact measurement initiatives.
          </p>
        </div>
      </div>

      <!-- Footer -->
      <div class="footer">
        <div class="footer-content">
          <p>This email was sent by {{companyName}}.</p>
        </div>

        <div class="footer-links">
          <a href="{{marketingUrl}}" class="footer-link">Visit Website</a>
          <a href="{{marketingUrl}}/pricing" class="footer-link">View Plans</a>
          <a href="mailto:{{supportEmail}}" class="footer-link">Contact Support</a>
          <a href="{{marketingUrl}}/privacy" class="footer-link">Privacy Policy</a>
        </div>

        <div class="footer-bottom">
          <p>&copy; {{year}} {{companyName}}. All rights reserved.</p>
        </div>
      </div>
      
    </div>
  </div>
</body>
</html>
